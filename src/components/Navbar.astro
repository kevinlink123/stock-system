---

<header class="header flex items-center justify-between sticky top-0 z-50 lg:px-8 px-2 py-5 bg-gray-50 border-b-2 border-red-200">
    <div class="title-container flex items-center gap-3">
        <div class="logo flex justify-center items-center h-10 w-10 bg-rose-300 rounded-xl text-xl">🧵</div>
        <h1 class="title text-2xl font-bold font-serif">Mercería{" "}<span class="block text-sm font-serif">Gestión de precios</span></h1>
    </div>
    <div class="button-container flex gap-2">
        <button class="add-category btn lg:px-5 px-2 border border-amber-900/20 bg-transparent text-amber-950 hover:bg-rose-100 hover:border-rose-400">
            <span class="lg:block hidden">+ Categoría</span>
            <span class="lg:hidden">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
            </span>
        </button>
        <button class="generate-pdf btn lg:px-5 px-3 bg-green-300/20 hover:text-gray-50 hover:bg-green-700/70">
            <span class="lg:block hidden">🖨 Imprimir PDF</span>
            <span class="lg:hidden">🖨</span>
        </button>
    </div>
</header>
<script>
    import { openNewCategoryModal } from "../scripts/eventBus";
import { generarPDF } from "../scripts/pdfHandler";

    const addCategoryBtn = document.querySelector("div.button-container button.add-category");
    const generatePDFBtn = document.querySelector("div.button-container button.generate-pdf");
    const hamburguerMenuBtn = document.querySelector("button.hamburguer-menu");
    const mobileMenu = document.querySelector("div.mobile-menu");

    hamburguerMenuBtn?.addEventListener("click", () => {
        mobileMenu?.classList.toggle("hidden");
    });

    generatePDFBtn?.addEventListener("click", async () => {
        await generarPDF();
    });
    addCategoryBtn?.addEventListener("click", () => {
        openNewCategoryModal();
    });


</script>